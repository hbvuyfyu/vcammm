<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- ── Collapsed state: just the floating icon ── -->
    <FrameLayout
        android:id="@+id/float_collapsed"
        android:layout_width="56dp"
        android:layout_height="56dp">

        <ImageView
            android:id="@+id/float_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_vcam_notif"
            android:background="@drawable/bg_float_icon"
            android:padding="8dp"
            android:elevation="8dp"
            android:contentDescription="VCam floating icon"/>
    </FrameLayout>

    <!-- ── Expanded state: full control panel ── -->
    <LinearLayout
        android:id="@+id/float_expanded"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_float_panel"
        android:padding="10dp"
        android:elevation="12dp"
        android:minWidth="220dp"
        android:visibility="gone">

        <!-- Header: status + target (draggable) -->
        <LinearLayout
            android:id="@+id/float_drag_handle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_status_dot"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tv_float_target"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:maxLines="1"
                android:text="VCam Active"/>

            <TextView
                android:id="@+id/tv_float_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B0C4DE"
                android:textSize="10sp"
                android:paddingStart="6dp"
                android:text="📷 صورة 1"/>

            <ImageButton
                android:id="@+id/btn_float_collapse"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_close"
                android:background="@android:color/transparent"
                android:tint="#FFFFFF"
                android:alpha="0.7"
                android:contentDescription="Collapse"
                android:padding="4dp"/>
        </LinearLayout>

        <!-- ── Slot switcher buttons: [1] [2] [3] [4] [5] ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/btn_slot_1"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="1"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_slot_btn_active"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Switch to slot 1"/>

            <TextView
                android:id="@+id/btn_slot_2"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="2"
                android:gravity="center"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_slot_btn_inactive"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Switch to slot 2"/>

            <TextView
                android:id="@+id/btn_slot_3"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="3"
                android:gravity="center"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_slot_btn_inactive"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Switch to slot 3"/>

            <TextView
                android:id="@+id/btn_slot_4"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="4"
                android:gravity="center"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_slot_btn_inactive"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Switch to slot 4"/>

            <TextView
                android:id="@+id/btn_slot_5"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="5"
                android:gravity="center"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_slot_btn_video"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Switch to slot 5 (video)"/>
        </LinearLayout>

        <!-- ── Control buttons row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_float_preview"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_view"
                android:background="@android:color/transparent"
                android:tint="#22C55E"
                android:contentDescription="Preview current slot"
                android:padding="8dp"/>

            <ImageButton
                android:id="@+id/btn_float_rotate"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_refresh"
                android:background="@android:color/transparent"
                android:tint="#4F8EF7"
                android:contentDescription="Rotate 90°"
                android:padding="8dp"/>

            <ImageButton
                android:id="@+id/btn_float_mirror"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_target"
                android:background="@android:color/transparent"
                android:tint="#4F8EF7"
                android:alpha="0.5"
                android:contentDescription="Mirror"
                android:padding="8dp"/>

            <ImageButton
                android:id="@+id/btn_float_stop"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_stop"
                android:background="@android:color/transparent"
                android:tint="#EF4444"
                android:contentDescription="Stop VCam"
                android:padding="8dp"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
