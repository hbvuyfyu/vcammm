<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- ── Collapsed: floating icon ── -->
    <FrameLayout
        android:id="@+id/float_collapsed"
        android:layout_width="60dp"
        android:layout_height="60dp">

        <ImageView
            android:id="@+id/float_icon"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_vcam_notif"
            android:background="@drawable/bg_float_icon"
            android:tint="@color/color_accent"
            android:padding="12dp"
            android:elevation="10dp"
            android:contentDescription="VCam floating icon"/>
    </FrameLayout>

    <!-- ── Expanded: control panel ── -->
    <LinearLayout
        android:id="@+id/float_expanded"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_float_panel"
        android:padding="16dp"
        android:elevation="16dp"
        android:visibility="gone">

        <!-- Header: status + target + collapse -->
        <LinearLayout
            android:id="@+id/float_drag_handle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="14dp">

            <!-- live dot -->
            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/bg_status_dot"
                android:layout_marginEnd="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_float_target"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_primary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:letterSpacing="0.02"
                    android:text="VCam Pro Active"/>

                <TextView
                    android:id="@+id/tv_float_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_accent"
                    android:textSize="10sp"
                    android:letterSpacing="0.05"
                    android:text="Photo Slot 1"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_float_collapse"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_close"
                android:background="@drawable/bg_float_btn_collapse"
                android:tint="@color/color_text_secondary"
                android:contentDescription="Collapse"
                android:padding="7dp"/>
        </LinearLayout>

        <!-- Divider line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginBottom="12dp"/>

        <!-- Section label: Photos -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PHOTOS"
            android:textColor="@color/color_accent"
            android:textSize="9sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.18"
            android:layout_marginBottom="8dp"/>

        <!-- Image slots 1–4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/btn_slot_1"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:text="1"
                android:gravity="center"
                android:textColor="@color/color_background"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_slot_btn_active"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Switch to slot 1"/>

            <TextView
                android:id="@+id/btn_slot_2"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:text="2"
                android:gravity="center"
                android:textColor="@color/color_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_slot_btn_inactive"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Switch to slot 2"/>

            <TextView
                android:id="@+id/btn_slot_3"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:text="3"
                android:gravity="center"
                android:textColor="@color/color_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_slot_btn_inactive"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Switch to slot 3"/>

            <TextView
                android:id="@+id/btn_slot_4"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:text="4"
                android:gravity="center"
                android:textColor="@color/color_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_slot_btn_inactive"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Switch to slot 4"/>
        </LinearLayout>

        <!-- Section label: Videos -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIDEOS"
            android:textColor="@color/video_accent"
            android:textSize="9sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.18"
            android:layout_marginBottom="8dp"/>

        <!-- Video slots 5–8 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/btn_slot_5"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:text="5"
                android:gravity="center"
                android:textColor="@color/color_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_slot_btn_video"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Switch to slot 5 (video)"/>

            <TextView
                android:id="@+id/btn_slot_6"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:text="6"
                android:gravity="center"
                android:textColor="@color/color_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_slot_btn_video"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Switch to slot 6 (video)"/>

            <TextView
                android:id="@+id/btn_slot_7"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:text="7"
                android:gravity="center"
                android:textColor="@color/color_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_slot_btn_video"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Switch to slot 7 (video)"/>

            <TextView
                android:id="@+id/btn_slot_8"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:text="8"
                android:gravity="center"
                android:textColor="@color/color_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_slot_btn_video"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Switch to slot 8 (video)"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginBottom="12dp"/>

        <!-- Control buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_float_preview"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:src="@android:drawable/ic_menu_view"
                android:background="@drawable/bg_float_btn_preview"
                android:tint="@color/color_accent"
                android:scaleType="fitCenter"
                android:padding="13dp"
                android:contentDescription="Preview current slot"/>

            <ImageButton
                android:id="@+id/btn_float_rotate"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_refresh"
                android:background="@drawable/bg_float_btn_rotate"
                android:tint="@color/color_purple"
                android:scaleType="fitCenter"
                android:padding="13dp"
                android:contentDescription="Rotate 90°"/>

            <ImageButton
                android:id="@+id/btn_float_mirror"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_target"
                android:background="@drawable/bg_float_btn_mirror"
                android:tint="@color/video_accent"
                android:scaleType="fitCenter"
                android:alpha="0.85"
                android:padding="13dp"
                android:contentDescription="Mirror"/>

            <ImageButton
                android:id="@+id/btn_float_stop"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_stop"
                android:background="@drawable/bg_float_btn_stop"
                android:tint="@color/error"
                android:scaleType="fitCenter"
                android:padding="13dp"
                android:contentDescription="Stop VCam"/>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
