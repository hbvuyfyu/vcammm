<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#08091A">

    <!-- Full-screen preview image -->
    <ImageView
        android:id="@+id/iv_preview_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="matrix"
        android:contentDescription="Preview"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Top bar — glass -->
    <LinearLayout
        android:id="@+id/preview_top_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="@color/overlay_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Live dot -->
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_status_dot"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/tv_preview_slot_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/color_text_primary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.02"
            android:text="Preview"/>

        <!-- Zoom label -->
        <TextView
            android:id="@+id/tv_preview_zoom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/color_accent"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginEnd="14dp"
            android:text="100%"/>

        <!-- Close button -->
        <ImageButton
            android:id="@+id/btn_preview_close"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_float_btn_collapse"
            android:tint="@color/color_text_primary"
            android:padding="8dp"
            android:contentDescription="Close"/>
    </LinearLayout>

    <!-- Bottom zoom controls — glass pill -->
    <LinearLayout
        android:id="@+id/preview_bottom_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/overlay_card"
        android:padding="8dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="36dp">

        <!-- Zoom out -->
        <Button
            android:id="@+id/btn_preview_zoom_out"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="−"
            android:textSize="26sp"
            android:textColor="@color/color_text_primary"
            android:backgroundTint="@color/neutral_100"
            style="@style/Widget.MaterialComponents.Button"/>

        <TextView
            android:layout_width="20dp"
            android:layout_height="wrap_content"
            android:text=""
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"/>

        <!-- Zoom in -->
        <Button
            android:id="@+id/btn_preview_zoom_in"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="+"
            android:textSize="26sp"
            android:textColor="@color/color_text_primary"
            android:backgroundTint="@color/neutral_100"
            style="@style/Widget.MaterialComponents.Button"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
