<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <!-- ══════════════════════════════════════════
         HEADER — Dark gradient + cyan accent line
         ══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_gradient_header"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:elevation="6dp">

        <!-- Icon + name -->
        <FrameLayout
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="14dp">
            <View
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_float_btn_preview"
                android:alpha="0.7"/>
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_camera_launcher"
                android:tint="@color/color_accent"
                android:contentDescription="Logo"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VCam Pro"
                android:textColor="@color/color_text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="System Virtual Camera"
                android:textColor="@color/color_text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.06"/>
        </LinearLayout>

        <!-- Root status badge -->
        <TextView
            android:id="@+id/tv_root_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ROOT"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:textColor="@color/color_root_ok"
            android:background="@drawable/bg_status_dot"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"/>
    </LinearLayout>

    <!-- ══════════════════════════════════════════
         SCROLLABLE CONTENT
         ══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/color_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- ────────────────────────────────────
                 SECTION: Photo Slots
                 ──────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <!-- neon accent bar -->
                <View
                    android:layout_width="3dp"
                    android:layout_height="20dp"
                    android:background="@color/color_accent"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PHOTO SLOTS"
                    android:textColor="@color/color_text_primary"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.14"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 – 4"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.05"/>
            </LinearLayout>

            <!-- ── SLOT 1 ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_slot_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/color_card_bg"
                app:cardElevation="6dp"
                app:strokeColor="@color/color_accent"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="10dp">

                    <!-- 3D badge -->
                    <TextView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:text="1"
                        android:textColor="@color/color_background"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_slot_badge"
                        android:layout_marginEnd="14dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/slot_image_1"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:id="@+id/tv_slot_1_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/slot_empty"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/iv_slot_1"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:scaleType="centerCrop"
                        android:background="@color/neutral_100"
                        android:visibility="gone"
                        android:contentDescription="Slot 1 thumbnail"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_pick_slot_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pick"
                        android:textSize="11sp"
                        android:textColor="@color/color_accent"
                        android:fontFamily="sans-serif-medium"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/color_accent"
                        app:cornerRadius="12dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SLOT 2 ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_slot_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/color_card_bg"
                app:cardElevation="4dp"
                app:strokeColor="@color/color_divider"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="10dp">
                    <TextView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:text="2"
                        android:textColor="@color/color_background"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_slot_badge"
                        android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/slot_image_2" android:textColor="@color/color_text_primary" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                        <TextView android:id="@+id/tv_slot_2_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/slot_empty" android:textColor="@color/color_text_secondary" android:textSize="11sp" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView android:id="@+id/iv_slot_2" android:layout_width="50dp" android:layout_height="50dp" android:scaleType="centerCrop" android:background="@color/neutral_100" android:visibility="gone" android:contentDescription="Slot 2" android:layout_marginEnd="8dp"/>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btn_pick_slot_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/pick" android:textSize="11sp" android:textColor="@color/color_accent" android:fontFamily="sans-serif-medium" style="@style/Widget.MaterialComponents.Button.OutlinedButton" app:strokeColor="@color/color_accent" app:cornerRadius="12dp" android:paddingStart="16dp" android:paddingEnd="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SLOT 3 ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_slot_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/color_card_bg"
                app:cardElevation="4dp"
                app:strokeColor="@color/color_divider"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="10dp">
                    <TextView android:layout_width="38dp" android:layout_height="38dp" android:text="3" android:textColor="@color/color_background" android:textSize="16sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_slot_badge" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/slot_image_3" android:textColor="@color/color_text_primary" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                        <TextView android:id="@+id/tv_slot_3_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/slot_empty" android:textColor="@color/color_text_secondary" android:textSize="11sp" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView android:id="@+id/iv_slot_3" android:layout_width="50dp" android:layout_height="50dp" android:scaleType="centerCrop" android:background="@color/neutral_100" android:visibility="gone" android:contentDescription="Slot 3" android:layout_marginEnd="8dp"/>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btn_pick_slot_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/pick" android:textSize="11sp" android:textColor="@color/color_accent" android:fontFamily="sans-serif-medium" style="@style/Widget.MaterialComponents.Button.OutlinedButton" app:strokeColor="@color/color_accent" app:cornerRadius="12dp" android:paddingStart="16dp" android:paddingEnd="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SLOT 4 ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_slot_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/color_card_bg"
                app:cardElevation="4dp"
                app:strokeColor="@color/color_divider"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="10dp">
                    <TextView android:layout_width="38dp" android:layout_height="38dp" android:text="4" android:textColor="@color/color_background" android:textSize="16sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_slot_badge" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/slot_image_4" android:textColor="@color/color_text_primary" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                        <TextView android:id="@+id/tv_slot_4_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/slot_empty" android:textColor="@color/color_text_secondary" android:textSize="11sp" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView android:id="@+id/iv_slot_4" android:layout_width="50dp" android:layout_height="50dp" android:scaleType="centerCrop" android:background="@color/neutral_100" android:visibility="gone" android:contentDescription="Slot 4" android:layout_marginEnd="8dp"/>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btn_pick_slot_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/pick" android:textSize="11sp" android:textColor="@color/color_accent" android:fontFamily="sans-serif-medium" style="@style/Widget.MaterialComponents.Button.OutlinedButton" app:strokeColor="@color/color_accent" app:cornerRadius="12dp" android:paddingStart="16dp" android:paddingEnd="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ────────────────────────────────────
                 SECTION: Video Slots
                 ──────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="20dp"
                    android:background="@color/video_accent"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="VIDEO SLOTS"
                    android:textColor="@color/color_text_primary"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.14"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 – 8"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.05"/>
            </LinearLayout>

            <!-- ── SLOT 5 ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_slot_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/color_card_bg"
                app:cardElevation="6dp"
                app:strokeColor="@color/video_accent"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="10dp">
                    <TextView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:text="5"
                        android:textColor="@color/color_background"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_slot_badge_video"
                        android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/slot_video_5" android:textColor="@color/color_text_primary" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                        <TextView android:id="@+id/tv_slot_5_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/slot_empty" android:textColor="@color/color_text_secondary" android:textSize="11sp" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView android:id="@+id/iv_slot_5" android:layout_width="50dp" android:layout_height="50dp" android:scaleType="centerCrop" android:background="@color/neutral_100" android:visibility="gone" android:contentDescription="Slot 5" android:layout_marginEnd="8dp"/>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btn_pick_slot_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/pick" android:textSize="11sp" android:textColor="@color/video_accent" android:fontFamily="sans-serif-medium" style="@style/Widget.MaterialComponents.Button.OutlinedButton" app:strokeColor="@color/video_accent" app:cornerRadius="12dp" android:paddingStart="16dp" android:paddingEnd="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SLOT 6 ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_slot_6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/color_card_bg"
                app:cardElevation="4dp"
                app:strokeColor="@color/color_divider"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="10dp">
                    <TextView android:layout_width="38dp" android:layout_height="38dp" android:text="6" android:textColor="@color/color_background" android:textSize="16sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_slot_badge_video" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/slot_video_6" android:textColor="@color/color_text_primary" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                        <TextView android:id="@+id/tv_slot_6_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/slot_empty" android:textColor="@color/color_text_secondary" android:textSize="11sp" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView android:id="@+id/iv_slot_6" android:layout_width="50dp" android:layout_height="50dp" android:scaleType="centerCrop" android:background="@color/neutral_100" android:visibility="gone" android:contentDescription="Slot 6" android:layout_marginEnd="8dp"/>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btn_pick_slot_6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/pick" android:textSize="11sp" android:textColor="@color/video_accent" android:fontFamily="sans-serif-medium" style="@style/Widget.MaterialComponents.Button.OutlinedButton" app:strokeColor="@color/video_accent" app:cornerRadius="12dp" android:paddingStart="16dp" android:paddingEnd="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SLOT 7 ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_slot_7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/color_card_bg"
                app:cardElevation="4dp"
                app:strokeColor="@color/color_divider"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="10dp">
                    <TextView android:layout_width="38dp" android:layout_height="38dp" android:text="7" android:textColor="@color/color_background" android:textSize="16sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_slot_badge_video" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/slot_video_7" android:textColor="@color/color_text_primary" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                        <TextView android:id="@+id/tv_slot_7_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/slot_empty" android:textColor="@color/color_text_secondary" android:textSize="11sp" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView android:id="@+id/iv_slot_7" android:layout_width="50dp" android:layout_height="50dp" android:scaleType="centerCrop" android:background="@color/neutral_100" android:visibility="gone" android:contentDescription="Slot 7" android:layout_marginEnd="8dp"/>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btn_pick_slot_7" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/pick" android:textSize="11sp" android:textColor="@color/video_accent" android:fontFamily="sans-serif-medium" style="@style/Widget.MaterialComponents.Button.OutlinedButton" app:strokeColor="@color/video_accent" app:cornerRadius="12dp" android:paddingStart="16dp" android:paddingEnd="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SLOT 8 ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_slot_8"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/color_card_bg"
                app:cardElevation="4dp"
                app:strokeColor="@color/color_divider"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="10dp">
                    <TextView android:layout_width="38dp" android:layout_height="38dp" android:text="8" android:textColor="@color/color_background" android:textSize="16sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_slot_badge_video" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/slot_video_8" android:textColor="@color/color_text_primary" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                        <TextView android:id="@+id/tv_slot_8_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/slot_empty" android:textColor="@color/color_text_secondary" android:textSize="11sp" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView android:id="@+id/iv_slot_8" android:layout_width="50dp" android:layout_height="50dp" android:scaleType="centerCrop" android:background="@color/neutral_100" android:visibility="gone" android:contentDescription="Slot 8" android:layout_marginEnd="8dp"/>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btn_pick_slot_8" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/pick" android:textSize="11sp" android:textColor="@color/video_accent" android:fontFamily="sans-serif-medium" style="@style/Widget.MaterialComponents.Button.OutlinedButton" app:strokeColor="@color/video_accent" app:cornerRadius="12dp" android:paddingStart="16dp" android:paddingEnd="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ════════════════════════════════════
                 ACTIVATE BUTTON — 3D green gradient
                 ════════════════════════════════════ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp">

                <!-- 3D shadow layer -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_btn_start"
                    android:translationY="4dp"
                    android:alpha="0.55"/>

                <!-- The actual button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_start_stop"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_gravity="top"
                    android:text="@string/start_vcam"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06"
                    android:textColor="@color/color_background"
                    android:enabled="false"
                    android:backgroundTint="@color/color_start"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_play"
                    app:iconGravity="textStart"
                    app:iconSize="22dp"
                    app:iconTint="@color/color_background"/>
            </FrameLayout>

            <!-- Hint text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/start_hint"
                android:textColor="@color/color_text_secondary"
                android:textSize="11sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Hidden legacy views — kept for binding compatibility, do NOT remove -->
    <View android:id="@+id/layout_media_type" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <ImageView android:id="@+id/iv_media_preview" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <androidx.cardview.widget.CardView android:id="@+id/card_media" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:cardBackgroundColor="@color/color_background">
        <TextView android:id="@+id/tv_media_selected" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_clear_media" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:visibility="gone" style="@style/Widget.MaterialComponents.Button.TextButton"/>
    </androidx.cardview.widget.CardView>
    <com.google.android.material.button.MaterialButton android:id="@+id/btn_pick_image" android:layout_width="0dp" android:layout_height="0dp" android:text="" android:visibility="gone" app:cornerRadius="0dp"/>
    <com.google.android.material.button.MaterialButton android:id="@+id/btn_pick_video" android:layout_width="0dp" android:layout_height="0dp" android:text="" android:visibility="gone" app:cornerRadius="0dp"/>

</LinearLayout>
