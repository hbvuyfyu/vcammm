<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/color_background"
    android:padding="32dp">

    <!-- Top glow accent -->
    <View
        android:layout_width="120dp"
        android:layout_height="1dp"
        android:background="@color/color_accent"
        android:alpha="0.4"
        android:layout_marginBottom="40dp"/>

    <!-- Logo with 3D ring -->
    <FrameLayout
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="28dp">

        <!-- outer glow ring -->
        <View
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:background="@drawable/bg_float_icon"
            android:alpha="0.35"/>

        <!-- icon container -->
        <FrameLayout
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center">
            <View
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/bg_float_icon"/>
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_camera_launcher"
                android:tint="@color/color_accent"
                android:contentDescription="VCam Pro logo"/>
        </FrameLayout>
    </FrameLayout>

    <!-- App name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VCam Pro"
        android:textColor="@color/color_text_primary"
        android:textSize="32sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.08"
        android:layout_marginBottom="8dp"/>

    <!-- Tagline -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="System-Level Virtual Camera"
        android:textColor="@color/color_accent"
        android:textSize="12sp"
        android:letterSpacing="0.15"
        android:layout_marginBottom="8dp"/>

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter your license key to unlock"
        android:textColor="@color/color_text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="40dp"/>

    <!-- License key input -->
    <EditText
        android:id="@+id/et_code"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_input_field"
        android:hint="License Key"
        android:textColorHint="@color/neutral_400"
        android:textColor="@color/color_text_primary"
        android:inputType="textPassword"
        android:gravity="center"
        android:textSize="16sp"
        android:letterSpacing="0.1"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="14dp"/>

    <!-- Unlock button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_submit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="UNLOCK ACCESS"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:textColor="@color/color_background"
        android:backgroundTint="@color/color_accent"
        app:cornerRadius="16dp"
        android:layout_marginBottom="20dp"/>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/color_accent"
        android:visibility="gone"
        android:layout_marginBottom="16dp"/>

    <!-- Status text -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/error"
        android:textSize="13sp"
        android:visibility="gone"/>

    <!-- Bottom accent -->
    <View
        android:layout_width="60dp"
        android:layout_height="1dp"
        android:background="@color/color_divider"
        android:layout_marginTop="40dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v2.0  ·  Root Required"
        android:textColor="@color/color_text_secondary"
        android:textSize="11sp"
        android:letterSpacing="0.05"
        android:layout_marginTop="10dp"/>

</LinearLayout>
