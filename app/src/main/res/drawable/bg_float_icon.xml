<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 3D shadow -->
    <item android:top="4dp" android:left="2dp">
        <shape android:shape="oval">
            <solid android:color="#8038BDF8"/>
        </shape>
    </item>
    <!-- gradient face -->
    <item android:bottom="3dp" android:right="1dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#1E3A5F"
                android:endColor="#0D1126"/>
            <stroke android:width="2dp" android:color="#38BDF8"/>
        </shape>
    </item>
</layer-list>
