<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 3D shadow layer -->
    <item android:top="3dp" android:left="1dp">
        <shape android:shape="oval">
            <solid android:color="#60F59E0B"/>
        </shape>
    </item>
    <!-- Main gradient face -->
    <item android:bottom="2dp" android:right="1dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FDE68A"
                android:endColor="#D97706"/>
            <stroke android:width="1dp" android:color="#F59E0B"/>
        </shape>
    </item>
</layer-list>
